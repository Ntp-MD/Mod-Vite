{
  "buildCommand": "npm run build",
  "outputDirectory": ".output/public",
  "installCommand": "npm install",
  "framework": "nuxtjs",
  "rewrites": [
    {
      "source": "/api/proxy/sheet",
      "destination": "/api/proxy/sheet"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
